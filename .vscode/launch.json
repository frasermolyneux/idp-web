{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "IDP Web",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/MX.IDP.Web/bin/Debug/net9.0/MX.IDP.Web.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/MX.IDP.Web",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:7100;http://localhost:5100"
            }
        },
        {
            "name": "IDP Web (watch)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "watch",
            "program": "${workspaceFolder}/src/MX.IDP.Web/bin/Debug/net9.0/MX.IDP.Web.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/MX.IDP.Web",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:7100;http://localhost:5100"
            }
        }
    ]
}
