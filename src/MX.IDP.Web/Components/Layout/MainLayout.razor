@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Identity.Web
@using System.Reflection
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

@{
    var entryAssembly = Assembly.GetEntryAssembly();
    var informationalVersion = entryAssembly?.GetCustomAttribute<AssemblyInformationalVersionAttribute>()?.InformationalVersion ?? "unknown";
    var buildVersion = informationalVersion.Split('+')[0];
    var assemblyVersion = entryAssembly?.GetName().Version?.ToString() ?? "unknown";
    var isChatPage = IsChatPage();
}

<div style="display: flex; flex-direction: column; height: 100vh; background: #1e1e1e;">
    <header style="background: #181818; border-bottom: 1px solid #333; height: 48px; padding: 0 16px; display: flex; align-items: center; justify-content: space-between;">
        <div style="display: flex; align-items: center; gap: 8px;">
            <FluentIcon Value="@(new Icons.Regular.Size24.Code())" Style="color: #0ea5e9;" />
            <span style="font-weight: 600; color: #e0e0e0; font-size: 15px;">IDP</span>
            <span style="color: #666; font-size: 13px;">Internal Developer Platform</span>
            <span style="color: #444; font-size: 11px; margin-left: 4px;" title="Full: @informationalVersion&#10;Assembly: @assemblyVersion">v@(buildVersion)</span>
            <span style="color: #333; margin: 0 4px;">|</span>
            <nav style="display: flex; align-items: center; gap: 4px; margin-left: 4px;">
                <a href="/" class="nav-link">Chat</a>
                <a href="/campaigns" class="nav-link">Campaigns</a>
                <a href="/campaigns/templates" class="nav-link">Templates</a>
                <a href="/campaigns/approvals" class="nav-link">Approvals</a>
                <a href="/knowledge" class="nav-link">Knowledge</a>
                <a href="/tools" class="nav-link">Tools</a>
            </nav>
        </div>
        <AuthorizeView>
            <Authorized>
                <div style="display: flex; align-items: center; gap: 10px; flex-shrink: 0;">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Person())" Style="color: #888;" />
                    <span style="color: #aaa; font-size: 13px;">@context.User.Identity?.Name</span>
                    <span style="color: #444;">|</span>
                    <a href="MicrosoftIdentity/Account/SignOut" style="color: #aaa; font-size: 13px; text-decoration: none; display: flex; align-items: center; gap: 4px;">
                        <FluentIcon Value="@(new Icons.Regular.Size16.ArrowExit())" Style="color: #aaa;" />
                        Sign out
                    </a>
                </div>
            </Authorized>
        </AuthorizeView>
    </header>
    <div style="display: flex; flex: 1; overflow: hidden;">
        <main class="@(isChatPage ? "chat-main" : "page-main")">
            <ErrorBoundary @ref="_errorBoundary">
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent Context="ex">
                    @{
                        HandleError(ex);
                    }
                    <div style="display: flex; align-items: center; justify-content: center; height: 100%; padding: 48px;">
                        <div style="text-align: center; max-width: 500px;">
                            <div style="font-size: 48px; margin-bottom: 16px;">🔐</div>
                            <h3 style="color: #e0e0e0; margin: 0 0 8px;">Session Expired</h3>
                            <p style="color: #888; margin: 0 0 16px;">Your authentication session needs to be refreshed.</p>
                            <a href="MicrosoftIdentity/Account/SignIn" class="btn-accent" style="text-decoration: none; display: inline-block;">Sign In Again</a>
                        </div>
                    </div>
                </ErrorContent>
            </ErrorBoundary>
        </main>
        @if (isChatPage)
        {
            <nav class="sidebar">
                <div class="sidebar-header">
                    <FluentButton Appearance="Appearance.Accent" OnClick="StartNewChat" Style="width: 100%;"
                        IconStart="@(new Icons.Regular.Size20.Add())">
                        New Chat
                    </FluentButton>
                </div>
                <div class="sidebar-conversations">
                    <ConversationList />
                </div>
            </nav>
        }
    </div>
</div>

@code {
    private ErrorBoundary? _errorBoundary;

    protected override void OnParametersSet()
    {
        // Reset error boundary when navigating to a new page
        _errorBoundary?.Recover();
    }

    private bool IsChatPage()
    {
        var uri = Navigation.ToBaseRelativePath(Navigation.Uri).TrimEnd('/');
        return string.IsNullOrEmpty(uri) || uri.StartsWith("?") || uri.StartsWith("chat", StringComparison.OrdinalIgnoreCase);
    }

    private void HandleError(Exception ex)
    {
        // Auto-redirect for auth failures
        if (ex is MicrosoftIdentityWebChallengeUserException ||
            ex.InnerException is Microsoft.Identity.Client.MsalUiRequiredException ||
            ex.Message.Contains("IDW10502"))
        {
            Navigation.NavigateTo("MicrosoftIdentity/Account/SignIn", forceLoad: true);
        }
    }

    private void StartNewChat()
    {
        Navigation.NavigateTo("/", forceLoad: true);
    }
}
