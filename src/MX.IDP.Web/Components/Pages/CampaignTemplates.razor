@page "/campaigns/templates"
@using Microsoft.AspNetCore.Authorization
@using MX.IDP.Web.Services
@attribute [Authorize]
@inject ICampaignApiService CampaignApi
@inject NavigationManager Navigation

<div class="campaigns-container">
    <div class="campaigns-header">
        <div>
            <h2 style="margin: 0 0 4px; color: #e0e0e0;">📋 Campaign Templates</h2>
            <p style="margin: 0; color: #888; font-size: 13px;">Pre-built campaigns for common scenarios. Pick a template to get started quickly.</p>
        </div>
        <a href="/campaigns" class="btn-secondary" style="text-decoration: none;">← Back to Campaigns</a>
    </div>

    @if (!string.IsNullOrEmpty(_statusMessage))
    {
        <div class="campaign-alert @_statusClass">@_statusMessage</div>
    }

    @if (_loading)
    {
        <p style="color: #888; text-align: center; padding: 40px;">Loading templates...</p>
    }
    else if (_templates.Count == 0)
    {
        <div class="campaign-empty-state">
            <div style="font-size: 48px; margin-bottom: 12px;">📋</div>
            <h3 style="color: #e0e0e0; margin: 0 0 8px;">No templates available</h3>
            <p style="color: #888;">Templates are defined in the backend. Check the API connection.</p>
        </div>
    }
    else
    {
        <div class="template-categories">
            @foreach (var category in _categories)
            {
                <button class="@(category == _selectedCategory ? "category-tab active" : "category-tab")"
                        @onclick="() => _selectedCategory = category">
                    @FormatCategory(category)
                </button>
            }
        </div>

        <div class="template-grid">
            @foreach (var template in FilteredTemplates)
            {
                <div class="template-card">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                        <div class="template-icon">@template.Icon</div>
                        <span class="source-badge">@FormatSourceType(template.SourceType)</span>
                    </div>
                    <h3 style="color: #e0e0e0; margin: 10px 0 4px; font-size: 15px;">@template.Name</h3>
                    <p style="color: #888; font-size: 13px; margin: 0 0 12px; line-height: 1.5; min-height: 40px;">@template.Description</p>
                    <button class="btn-accent" style="width: 100%;" @onclick="() => CreateFromTemplate(template)" disabled="@_creating">
                        @(_creatingId == template.Id ? "Creating..." : "Use Template →")
                    </button>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<CampaignTemplateSummary> _templates = [];
    private List<string> _categories = [];
    private string _selectedCategory = "all";
    private bool _loading = true;
    private bool _creating;
    private string? _creatingId;
    private string? _statusMessage;
    private string _statusClass = "";

    private IEnumerable<CampaignTemplateSummary> FilteredTemplates =>
        _selectedCategory == "all" ? _templates : _templates.Where(t => t.Category == _selectedCategory);

    protected override async Task OnInitializedAsync()
    {
        try { _templates = await CampaignApi.ListTemplatesAsync(); }
        catch { _templates = []; }

        _categories = ["all", .. _templates.Select(t => t.Category).Distinct().OrderBy(c => c)];
        _loading = false;
    }

    private async Task CreateFromTemplate(CampaignTemplateSummary template)
    {
        _creating = true;
        _creatingId = template.Id;
        try
        {
            await CampaignApi.CreateFromTemplateAsync(template.Id);
            _statusMessage = $"Campaign '{template.Name}' created — redirecting...";
            _statusClass = "success";
            StateHasChanged();
            await Task.Delay(800);
            Navigation.NavigateTo("/campaigns");
        }
        catch
        {
            _statusMessage = "Failed to create campaign from template";
            _statusClass = "error";
        }
        finally
        {
            _creating = false;
            _creatingId = null;
        }
    }

    private static string FormatCategory(string category) => category switch
    {
        "all" => "All",
        "security" => "🔒 Security",
        "cost" => "💰 Cost",
        "compliance" => "📜 Compliance",
        "hygiene" => "🧹 Hygiene",
        _ => category
    };

    private static string FormatSourceType(string sourceType) => sourceType switch
    {
        "advisor" => "Advisor",
        "policy" => "Policy",
        "dev_standards" => "Dev Standards",
        "repo_config" => "Repo Config",
        "dependabot" => "Dependabot",
        "codeql" => "CodeQL",
        "kql" => "KQL",
        _ => sourceType
    };
}
