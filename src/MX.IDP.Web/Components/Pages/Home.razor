@page "/"
@page "/chat/{ConversationId?}"
@using MX.IDP.Web.Models
@using MX.IDP.Web.Services
@using Markdig
@using Microsoft.AspNetCore.Components.Authorization
@using System.Diagnostics
@using Microsoft.Identity.Web
@using Microsoft.JSInterop
@inject IChatApiService ChatApi
@inject IConversationService ConversationService
@inject AuthenticationStateProvider AuthStateProvider
@inject ConversationNotifier ConversationNotifier
@inject NavigationManager Navigation
@inject IJSRuntime JS
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>IDP Chat</PageTitle>

<div class="chat-messages" @ref="_messagesContainer">
    @if (_messages.Count == 0 && !_isLoading)
    {
        <div class="empty-state">
            <div class="terminal-welcome">
                <div><span class="prompt">&gt;</span> <span class="highlight">Welcome to IDP</span></div>
                <div><span class="prompt">&gt;</span> Type a message to get started.</div>
                <div><span class="prompt">&gt;</span></div>
                <div><span class="prompt">&gt;</span> Examples:</div>
                <div><span class="prompt">&gt;</span> <span class="example">"Show me non-compliant resources in dev"</span></div>
                <div><span class="prompt">&gt;</span> <span class="example">"What's the status of my deployments?"</span></div>
                <div><span class="prompt">&gt;</span> <span class="example">"List all Azure Advisor recommendations"</span></div>
                <div><span class="prompt">&gt;</span> <span class="cursor-blink"></span></div>
            </div>
        </div>
    }
    @for (int i = 0; i < _messages.Count; i++)
    {
        var msg = _messages[i];
        var index = i;
        if (msg.Role == "user")
        {
            <div class="chat-bubble-user">
                <div class="chat-card">
                    <div class="chat-role">you &gt;</div>
                    @((MarkupString)Markdown.ToHtml(msg.Content, _markdownPipeline))
                </div>
            </div>
        }
        else
        {
            <div class="chat-bubble-assistant">
                <div class="chat-card">
                    <div class="chat-role">idp &gt;</div>
                    @if (_agentEyeEnabled && _debugInfo.ContainsKey(index) && _debugInfo[index].Logprobs is not null)
                    {
                        <div class="agent-eye-overlay">
                            @foreach (var tokenInfo in _debugInfo[index].Logprobs!)
                            {
                                var prob = Math.Exp(tokenInfo.Logprob);
                                var colorClass = prob >= 0.9 ? "token-high" : prob >= 0.5 ? "token-medium" : "token-low";
                                <span class="token-span @colorClass" title="@FormatTokenTooltip(tokenInfo)">@tokenInfo.Token</span>
                            }
                        </div>
                    }
                    else
                    {
                        @((MarkupString)Markdown.ToHtml(msg.Content, _markdownPipeline))
                    }
                    @if (_debugInfo.ContainsKey(index) && _debugInfo[index].FunctionCalls is not null)
                    {
                        <button class="debug-toggle" @onclick="() => ToggleFunctionTrace(index)">
                            <FluentIcon Value="@(new Icons.Regular.Size20.Wrench())" Style="width: 14px; height: 14px;" />
                            @(_expandedFunctionTrace.Contains(index) ? "hide tool trace" : $"tool trace ({_debugInfo[index].FunctionCalls!.Count})")
                        </button>
                        @if (_expandedFunctionTrace.Contains(index))
                        {
                            <div class="function-trace-panel">
                                @foreach (var fc in _debugInfo[index].FunctionCalls!.OrderBy(f => f.Order))
                                {
                                    <div class="function-call-item">
                                        <span class="function-call-name">⚡ @fc.ToolName</span>
                                        @if (fc.Arguments is not null && fc.Arguments.Count > 0)
                                        {
                                            <span class="function-call-args">(@string.Join(", ", fc.Arguments.Select(a => $"{a.Key}={a.Value}")))</span>
                                        }
                                        @if (fc.ResultPreview is not null)
                                        {
                                            <div class="function-call-result">→ @fc.ResultPreview</div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }
                    @if (_debugInfo.ContainsKey(index))
                    {
                        <button class="debug-toggle" @onclick="() => ToggleDebug(index)">
                            <FluentIcon Value="@(new Icons.Regular.Size20.Info())" Style="width: 14px; height: 14px;" />
                            @(_expandedDebug.Contains(index) ? "hide details" : "show details")
                        </button>
                        @if (_expandedDebug.Contains(index))
                        {
                            <div class="debug-panel">
                                <div>Agent: @(_debugInfo[index].Agent ?? "—")</div>
                                <div>Response time: @_debugInfo[index].ResponseTimeMs ms</div>
                                <div>Conversation: @(_currentConversationId ?? "—")</div>
                                <div>Timestamp: @msg.Timestamp.ToString("yyyy-MM-dd HH:mm:ss UTC")</div>
                                @if (_debugInfo[index].Usage is not null)
                                {
                                    <div>Prompt tokens: @_debugInfo[index].Usage!.PromptTokens</div>
                                    <div>Completion tokens: @_debugInfo[index].Usage!.CompletionTokens</div>
                                    <div>Total tokens: @_debugInfo[index].Usage!.TotalTokens</div>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        }
    }
    @if (_isLoading)
    {
        <div class="chat-bubble-assistant">
            <div class="loading-indicator">
                <FluentProgressRing Style="width: 16px; height: 16px;" />
                <span>Processing...</span>
            </div>
        </div>
    }
</div>

<div class="chat-input-area">
    <div class="chat-input-row">
        <span class="chat-prompt-prefix">&gt;</span>
        <textarea @bind="_userInput" @bind:event="oninput" @onkeydown="HandleKeyDown" @onkeydown:preventDefault="_preventEnter"
            placeholder="Ask me anything..." rows="1" disabled="@_isLoading"
            class="chat-textarea"></textarea>
        <button class="send-btn" @onclick="SendMessage"
            disabled="@(string.IsNullOrWhiteSpace(_userInput) || _isLoading)">
            <FluentIcon Value="@(new Icons.Regular.Size20.Send())" Color="Color.Custom" CustomColor="white" />
            Send
        </button>
    </div>
    <div class="chat-input-hint">
        <span>Press Enter to send · Shift+Enter for new line</span>
        <span class="chat-controls">
            <button class="agent-eye-toggle @(_agentEyeEnabled ? "active" : "")" @onclick="() => _agentEyeEnabled = !_agentEyeEnabled"
                title="Toggle Agent Eye — view token probabilities and tool traces">
                <FluentIcon Value="@(new Icons.Regular.Size16.Eye())" Style="width: 12px; height: 12px;" />
                Agent Eye
            </button>
            @if (_totalRequests > 0)
            {
                <span class="token-summary">
                    <FluentIcon Value="@(new Icons.Regular.Size16.DataUsage())" Style="width: 12px; height: 12px; vertical-align: middle;" />
                    @_totalRequests requests · @_totalTokens tokens (@_totalPromptTokens prompt + @_totalCompletionTokens completion)
                </span>
            }
        </span>
    </div>
</div>

@code {
    [Parameter] public string? ConversationId { get; set; }

    private List<ChatMessage> _messages = new();
    private string? _userInput;
    private bool _isLoading;
    private string? _currentConversationId;
    private string? _userId;
    private ElementReference _messagesContainer;
    private Dictionary<int, MessageDebugInfo> _debugInfo = new();
    private HashSet<int> _expandedDebug = new();
    private bool _preventEnter;
    private bool _agentEyeEnabled;
    private int _totalRequests;
    private int _totalTokens;
    private int _totalPromptTokens;
    private int _totalCompletionTokens;
    private HashSet<int> _expandedFunctionTrace = new();

    private static readonly MarkdownPipeline _markdownPipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .Build();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            await JS.InvokeVoidAsync("eval", "document.querySelector('.chat-messages')?.scrollTo(0, document.querySelector('.chat-messages').scrollHeight)");
        }
        catch
        {
            // Ignore JS interop errors during prerendering
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _userId = authState.User.FindFirst("http://schemas.microsoft.com/identity/claims/objectidentifier")?.Value
                ?? authState.User.FindFirst("oid")?.Value
                ?? "anonymous";
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(ConversationId) && ConversationId != _currentConversationId)
        {
            _currentConversationId = ConversationId;
            _messages = await ConversationService.GetMessagesAsync(ConversationId);
            ResetSessionCounters();
        }
        else if (string.IsNullOrEmpty(ConversationId) && _currentConversationId != null)
        {
            _currentConversationId = null;
            _messages = new();
            ResetSessionCounters();
        }
    }

    private void ResetSessionCounters()
    {
        _debugInfo.Clear();
        _expandedDebug.Clear();
        _totalRequests = 0;
        _totalTokens = 0;
        _totalPromptTokens = 0;
        _totalCompletionTokens = 0;
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_userInput)) return;

        var userMessage = new ChatMessage { Role = "user", Content = _userInput.Trim() };
        _messages.Add(userMessage);
        var messageText = _userInput.Trim();
        _userInput = string.Empty;
        _isLoading = true;
        StateHasChanged();

        try
        {
            if (_currentConversationId == null)
            {
                var conversation = await ConversationService.GetOrCreateConversationAsync(_userId!, null);
                _currentConversationId = conversation.Id;

                var title = messageText.Length > 50 ? messageText[..50] + "..." : messageText;
                await ConversationService.UpdateConversationTitleAsync(_currentConversationId, title);
                ConversationNotifier.NotifyChanged();
            }

            await ConversationService.SaveMessageAsync(_currentConversationId, userMessage);

            var stopwatch = Stopwatch.StartNew();
            var response = await ChatApi.SendMessageAsync(messageText, _currentConversationId, _messages);
            stopwatch.Stop();

            var assistantMessage = new ChatMessage { Role = "assistant", Content = response.Message };
            _messages.Add(assistantMessage);

            var assistantIndex = _messages.Count - 1;
            _debugInfo[assistantIndex] = new MessageDebugInfo
            {
                ResponseTimeMs = stopwatch.ElapsedMilliseconds,
                Agent = response.Agent,
                Usage = response.Usage,
                Logprobs = response.Logprobs,
                FunctionCalls = response.FunctionCalls
            };

            _totalRequests++;
            if (response.Usage is not null)
            {
                _totalPromptTokens += response.Usage.PromptTokens;
                _totalCompletionTokens += response.Usage.CompletionTokens;
                _totalTokens += response.Usage.TotalTokens;
            }

            await ConversationService.SaveMessageAsync(_currentConversationId, assistantMessage);
        }
        catch (MicrosoftIdentityWebChallengeUserException)
        {
            Navigation.NavigateTo("MicrosoftIdentity/Account/SignIn", forceLoad: true);
            return;
        }
        catch (Exception ex)
        {
            _messages.Add(new ChatMessage { Role = "assistant", Content = $"Sorry, an error occurred: {ex.Message}" });
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            _preventEnter = true;
            await SendMessage();
        }
        else
        {
            _preventEnter = false;
        }
    }

    private void ToggleDebug(int index)
    {
        if (!_expandedDebug.Remove(index))
        {
            _expandedDebug.Add(index);
        }
    }

    private void ToggleFunctionTrace(int index)
    {
        if (!_expandedFunctionTrace.Remove(index))
        {
            _expandedFunctionTrace.Add(index);
        }
    }

    private static string FormatTokenTooltip(TokenLogprobInfo token)
    {
        var prob = Math.Exp(token.Logprob);
        var tooltip = $"Token: \"{token.Token}\"\nProbability: {prob:P1}\nLogprob: {token.Logprob:F4}";

        if (token.TopAlternatives.Count > 0)
        {
            tooltip += "\n\nAlternatives:";
            foreach (var alt in token.TopAlternatives.Take(5))
            {
                var altProb = Math.Exp(alt.Logprob);
                tooltip += $"\n  \"{alt.Token}\" — {altProb:P1}";
            }
        }

        return tooltip;
    }

    private class MessageDebugInfo
    {
        public long ResponseTimeMs { get; set; }
        public string? Agent { get; set; }
        public TokenUsageInfo? Usage { get; set; }
        public List<TokenLogprobInfo>? Logprobs { get; set; }
        public List<FunctionCallInfo>? FunctionCalls { get; set; }
    }
}
